{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "title": "DocumentQA RAG",
  "uid": "documentqa-rag",
  "tags": ["rag", "documentqa"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate (req/s) by tenant",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum by (tenant) (rate(rag_requests_total[5m]))", "legendFormat": "{{tenant}}", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active SSE streams",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [ { "expr": "sum(rag_active_streams)", "refId": "A" } ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Guard blocks (last 1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [ { "expr": "sum(increase(rag_guard_blocks_total[1h]))", "refId": "A" } ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request latency (seconds)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(rag_request_duration_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(rag_request_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Time to first token p95 (seconds)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(rag_ttft_seconds_bucket[5m])))", "legendFormat": "p95 TTFT", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Tokens/min by tenant & direction",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sum by (tenant, direction) (rate(rag_tokens_total[5m])) * 60", "legendFormat": "{{tenant}} {{direction}}", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "Cache hit ratio (15m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "targets": [
        { "expr": "sum(rate(rag_requests_total{cache_hit=\"true\"}[15m])) / clamp_min(sum(rate(rag_requests_total[15m])), 1)", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Estimated cost (last 24h, USD)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "targets": [ { "expr": "sum(increase(rag_cost_usd_total[24h]))", "refId": "A" } ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "HTTP 5xx error rate",
      "description": "Uses ASP.NET Core instrumentation. If empty, confirm the exact metric name on /metrics (varies by OTel version).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        { "expr": "sum(rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_request_duration_seconds_count[5m])), 1)", "legendFormat": "5xx ratio", "refId": "A" }
      ]
    }
  ]
}
