{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.DataProtection": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Qdrant": {
    "Host": "localhost",
    "Port": 6334
  },
  "Rag": {
    "ChunkSize": 1500,
    "ChunkOverlap": 200,
    "RetrievalTopK": 20,
    "RerankTopN": 10,
    "MinRelevanceScore": 0.3,
    "UtilityModel": "gpt-4o-mini",
    "QueryExpansionEnabled": true,
    "RerankerStrategy": "crossencoder",
    "ChunkingStrategy": "structural",
    "OcrEnabled": true,
    "OcrMinWords": 40,
    "EmbeddingModel": "text-embedding-3-small",
    "EmbeddingDimensions": 1536,
    "MaxContextTokens": 6000,
    "MaxHistoryTurns": 6,
    "SimpleModel": "gpt-4o-mini",
    "ComplexModel": "gpt-4o",
    "MultimodalEnabled": false,
    "EnrichmentEnabled": false
  },
  "Reranker": {
    "Provider": "cohere",
    "ApiKey": ""
  },
  "Cache": {
    "Enabled": true,
    "SimilarityThreshold": 0.95,
    "TtlMinutes": 60
  },
  "Concurrency": {
    "MaxLlmCalls": 20
  },
  "Langfuse": {
    "Enabled": false,
    "PublicKey": "",
    "SecretKey": "",
    "BaseUrl": "https://cloud.langfuse.com"
  },
  "ApiKeys": {},
  "Tiers": {
    "free": {
      "TokensPerMinute": 5000,
      "Models": [ "meta-llama/llama-3.1-8b-instruct", "meta-llama/llama-3.2-3b-instruct:free" ]
    },
    "pro": {
      "TokensPerMinute": 20000,
      "Models": [ "anthropic/claude-3.5-haiku", "openai/gpt-4o-mini" ]
    },
    "enterprise": {
      "TokensPerMinute": 100000,
      "Models": [ "anthropic/claude-opus-4", "openai/gpt-4o" ]
    }
  },
  "OpenRouter": {
    "ApiKey": "",
    "BaseUrl": "https://openrouter.ai/api/v1"
  },
  "Redis": {
    "ConnectionString": ""
  },
  "UsageDb": {
    "Path": "usage.db"
  }
}
